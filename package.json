{
  "name": "chatgpt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env --watch server/index.mjs",
    "build": "tsc -b && vite build",
    "build:free": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --env-file=.env server/index.mjs",
    "functions:install": "npm install --prefix functions",
    "firebase:deploy": "npm run build && npx firebase-tools deploy --only hosting,functions",
    "firebase:deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "pages:deploy": "npm run build:free"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "openai": "^6.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
